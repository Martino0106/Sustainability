              style={{ ...S.btn("ghost"), fontSize: 9, padding: "6px 14px" }}
            >
              {notesOpen ? "✕ NOTES" : "✎ NOTES"}
            </button>
          )}
          {screen === "case" && (
            <button
              onClick={() => setScreen("home")}
              style={{ ...S.btn("ghost"), fontSize: 9, padding: "6px 14px" }}
            >← ALL CASES</button>
          )}
        </div>
      </div>

      {/* NOTES PANEL */}
      {notesOpen && screen === "case" && (
        <div style={{
          position: "fixed", right: 0, top: 56, bottom: 0, width: 280,
          background: "#fdf8ef", borderLeft: "2px solid #8b1a1a", zIndex: 150,
          display: "flex", flexDirection: "column",
        }}>
          <div style={{ padding: "14px 16px", borderBottom: "1px solid #c8b090" }}>
            <div style={{ fontSize: 8, letterSpacing: 5, color: "#8b1a1a" }}>INVESTIGATOR'S NOTES</div>
          </div>
          <textarea
            value={notes}
            onChange={e => setNotes(e.target.value)}
            placeholder={"Jot suspects, contradictions,\nalibi gaps, evidence links...\n\n─────────────────"}
            style={{
              flex: 1, background: "transparent", border: "none", outline: "none",
              padding: "16px", fontSize: 12, fontFamily: "'Georgia', serif",
              color: "#2a1e14", lineHeight: 1.8, resize: "none",
            }}
          />
        </div>
      )}

      <div style={{ ...S.wrap, paddingRight: notesOpen && screen === "case" ? 304 : 24 }}>

        {/* ═══════════ HOME ═══════════ */}
        {screen === "home" && (
          <div>
            <div style={{ marginBottom: 48 }}>
              <div style={{ ...S.tag(), marginBottom: 12 }}>CLASSIFIED ARCHIVE · EU ENVIRONMENTAL CRIMES DIVISION</div>
              <h1 style={{ fontSize: 42, fontWeight: "bold", letterSpacing: 1, margin: "0 0 10px", lineHeight: 1.05, color: "#1a1410" }}>
                DOSSIER<br />EUROPA
              </h1>
              <div style={{ width: 60, height: 3, background: "#8b1a1a", margin: "12px 0 16px" }} />
              <p style={{ maxWidth: 560, fontSize: 14, lineHeight: 1.85, color: "#4a3828", fontStyle: "italic" }}>
                Three unsolved deaths. Three of Europe's most consequential environmental scandals. The institutions survived. The truth did not. Your task is to find who pulled the trigger — before the dossier is sealed.
              </p>
            </div>

            <div>
              {CASES.map((c, i) => (
                <div
                  key={c.id}
                  style={S.caseCard}
                  onClick={() => startCase(c)}
                  onMouseEnter={e => { e.currentTarget.style.background = "#fff8f0"; e.currentTarget.style.borderColor = "#8b1a1a"; }}
                  onMouseLeave={e => { e.currentTarget.style.background = "#faf6ed"; e.currentTarget.style.borderColor = "#2a2010"; }}
                >
                  <div style={{
                    position: "absolute", top: 0, left: 0, bottom: 0, width: 5,
                    background: ["#8b1a1a", "#2a4a8b", "#2a6a2a"][i],
                  }} />
                  <div style={{ ...S.caseCardInner, paddingLeft: 32 }}>
                    <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start" }}>
                      <div style={{ flex: 1 }}>
                        <div style={{ display: "flex", gap: 10, alignItems: "center", marginBottom: 8 }}>
                          <span style={{ fontSize: 22 }}>{c.flag}</span>
                          <span style={{ ...S.tag(["#8b1a1a","#2a4a8b","#2a6a2a"][i]), marginBottom: 0 }}>{c.country} · {c.era}</span>
                          <span style={{ fontSize: 8, letterSpacing: 4, color: "#9a8a7a" }}>CASE {c.id}</span>
                        </div>
                        <div style={S.caseTitle}>{c.title}</div>
                        <div style={S.caseSub}>{c.subtitle}</div>
                        <div style={{ fontSize: 12, color: "#5a4838", lineHeight: 1.7, maxWidth: 620 }}>{c.setting.slice(0, 180)}…</div>
                      </div>
                      <div style={{ marginLeft: 24, textAlign: "right", flexShrink: 0 }}>
                        <div style={{ fontSize: 9, color: "#9a8a7a", letterSpacing: 3, marginBottom: 4 }}>{c.suspects.length} SUSPECTS</div>
                        <div style={{ fontSize: 36, opacity: 0.15 }}>⚖</div>
                      </div>
                    </div>
                    <div style={{ marginTop: 14, paddingTop: 12, borderTop: "1px solid #d8c8a8", fontSize: 10, color: "#9a7a5a", letterSpacing: 2 }}>
                      INSPIRED BY // {c.realInspiration.slice(0, 90)}…
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ═══════════ CASE SCREEN ═══════════ */}
        {screen === "case" && selectedCase && (
          <div>
            {/* BRIEFING */}
            {phase === 1 && (
              <div>
                <div style={{ display: "flex", gap: 12, alignItems: "center", marginBottom: 8 }}>
                  <span style={{ fontSize: 24 }}>{selectedCase.flag}</span>
                  <div>
                    <div style={{ ...S.tag(), marginBottom: 2 }}>CASE {selectedCase.id} · {selectedCase.country}</div>
                    <h2 style={{ fontSize: 30, fontWeight: "bold", margin: 0, letterSpacing: 1 }}>{selectedCase.title}</h2>
                    <div style={{ fontSize: 14, fontStyle: "italic", color: "#6a5040", marginTop: 2 }}>{selectedCase.subtitle}</div>
                  </div>
                </div>

                <div style={{ width: "100%", height: 2, background: "linear-gradient(to right, #8b1a1a, transparent)", marginBottom: 28 }} />

                <div style={S.box("#fff8f0")}>
                  <p style={{ ...S.label(), marginBottom: 10 }}>▸ SCENE OF THE CRIME</p>
                  <p style={{ ...S.bodyText, fontSize: 13 }}>{selectedCase.setting}</p>
                </div>

                <div style={{ ...S.box("#fdf0e8"), border: "2px solid #8b1a1a" }}>
                  <p style={S.label()}>☠ THE VICTIM</p>
                  <div style={{ display: "flex", gap: 20, alignItems: "flex-start" }}>
                    <div style={{
                      width: 72, height: 72, border: "2px solid #8b1a1a", flexShrink: 0,
                      display: "flex", alignItems: "center", justifyContent: "center",
                      fontSize: 28, background: "#f0ebe0",
                    }}>💀</div>
                    <div>
                      <div style={{ fontSize: 18, fontWeight: "bold", letterSpacing: 2, marginBottom: 2 }}>{selectedCase.victim.name}</div>
                      <div style={{ fontSize: 10, letterSpacing: 3, color: "#8b1a1a", marginBottom: 10 }}>{selectedCase.victim.role}</div>
                      <p style={{ ...S.bodyText, marginBottom: 12 }}>{selectedCase.victim.bio}</p>
                      <div style={{ background: "#f0ebe0", border: "1px dashed #c8a060", padding: "10px 14px", fontSize: 12, color: "#5a3a18" }}>
                        <span style={S.label("#c8a060")}>KEY DETAIL FOR INVESTIGATORS</span>
                        {selectedCase.victim.clue}
                      </div>
                    </div>
                  </div>
                </div>

                <button style={S.btn("primary")} onClick={() => setPhase(2)}>
                  COMMENCE INVESTIGATION →
                </button>
              </div>
            )}

            {/* INVESTIGATION */}
            {phase === 2 && (
              <div>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-end", marginBottom: 24 }}>
                  <div>
                    <div style={{ ...S.tag(), marginBottom: 6 }}>INVESTIGATION ACTIVE · {selectedCase.id}</div>
                    <h2 style={{ fontSize: 22, fontWeight: "bold", margin: 0, letterSpacing: 1 }}>{selectedCase.title}</h2>
                  </div>
                  <div style={{ fontSize: 10, color: "#8b1a1a", letterSpacing: 3 }}>
                    {unlockedEvidence.length}/{suspectCount} EVIDENCE FILES OPENED
                  </div>
                </div>

                <div style={{ marginBottom: 24 }}>
                  {selectedCase.suspects.map((s, i) => {
                    const isOpen = openSuspect === i;
                    const hasEvidence = unlockedEvidence.includes(i);
                    const hasSecret = unlockedSecrets.includes(i);
                    return (
                      <div key={i} style={S.suspectCard(isOpen)}>
                        <div style={S.suspectHeader} onClick={() => setOpenSuspect(isOpen ? null : i)}>
                          <div style={{ display: "flex", alignItems: "center", gap: 16 }}>
                            <div style={{
                              width: 40, height: 40, border: `2px solid ${isOpen ? "#8b1a1a" : "#c8b090"}`,
                              display: "flex", alignItems: "center", justifyContent: "center", fontSize: 18, background: "#f0ebe0",
                            }}>
                              {["🧑‍💼","👩‍⚖️","🕵","👩‍💻"][i] || "🧑"}
                            </div>
                            <div>
                              <div style={S.suspectName}>{s.name}</div>
                              <div style={S.suspectRole}>{s.role} · Age {s.age}</div>
                            </div>
                          </div>
                          <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
                            {hasEvidence && <span style={{ fontSize: 8, letterSpacing: 3, color: "#2a6a2a", border: "1px solid #2a6a2a", padding: "2px 8px" }}>EVIDENCE ✓</span>}
                            {hasSecret && <span style={{ fontSize: 8, letterSpacing: 3, color: "#8b1a1a", border: "1px solid #8b1a1a", padding: "2px 8px" }}>SECRET ✓</span>}
                            <span style={{ fontSize: 11, color: "#c8a060" }}>{isOpen ? "▲" : "▼"}</span>
                          </div>
                        </div>

                        {isOpen && (
                          <div style={{ padding: "0 20px 20px" }}>
                            <div style={{ borderTop: "1px solid #d8c8a8", paddingTop: 16 }} />
                            <div style={S.gridTwo}>
                              <div style={S.infoBox("#fff4e8")}>
                                <span style={S.label("#c8640a")}>MOTIVE</span>
                                <p style={S.bodyText}>{s.motive}</p>
                              </div>
                              <div style={S.infoBox("#e8f0ff")}>
                                <span style={S.label("#2a4a8b")}>ALIBI</span>
                                <p style={S.bodyText}>{s.alibi}</p>
                              </div>
                            </div>
                            <div style={{ ...S.infoBox("#f8f4e8"), marginBottom: 14 }}>
                              <span style={S.label("#8b6a1a")}>BEHAVIOURAL TELL</span>
                              <p style={{ ...S.bodyText, fontStyle: "italic" }}>"{s.tell}"</p>
                            </div>
                            <div style={{ display: "flex", gap: 10 }}>
                              <button
                                onClick={() => setUnlockedEvidence(prev => prev.includes(i) ? prev : [...prev, i])}
                                style={{
                                  ...S.btn(hasEvidence ? "ghost" : "dark"),
                                  fontSize: 9, padding: "9px 16px",
                                  opacity: hasEvidence ? 0.7 : 1,
                                }}
                              >
                                {hasEvidence ? "✓ EVIDENCE EXAMINED" : "🔍 EXAMINE EVIDENCE"}
                              </button>
                              <button
                                onClick={() => setUnlockedSecrets(prev => prev.includes(i) ? prev : [...prev, i])}
                                style={{ ...S.btn("ghost"), fontSize: 9, padding: "9px 16px" }}
                              >
                                {hasSecret ? "✓ SECRET REVEALED" : "🗃 DIG DEEPER"}
                              </button>
                            </div>
                            {hasEvidence && (
                              <div style={{ ...S.infoBox("#fff0e0"), marginTop: 12, border: "1px dashed #c87a1a" }}>
                                <span style={S.label("#c87a1a")}>PHYSICAL EVIDENCE</span>
                                <p style={S.bodyText}>{s.evidence}</p>
                              </div>
                            )}
                            {hasSecret && (
                              <div style={{ ...S.infoBox("#fef0f0"), marginTop: hasEvidence ? 0 : 12, border: "1px dashed #8b1a1a", marginTop: 10 }}>
                                <span style={S.label("#8b1a1a")}>HIDDEN SECRET</span>
                                <p style={S.bodyText}>{s.secret}</p>
                              </div>
                            )}
                          </div>
                        )}
                      </div>
                    );
                  })}
                </div>

                {/* ACCUSATION PANEL */}
                {canAccuse ? (
                  <div style={{ ...S.box("#fdf0f0"), border: "2px solid #8b1a1a" }}>
                    <p style={S.label()}>⚖ FORMAL ACCUSATION</p>
                    <p style={{ fontSize: 12, color: "#5a3020", marginBottom: 16, lineHeight: 1.7 }}>
                      You have reviewed sufficient evidence. One accusation. No appeals. The full weight of your investigation rests on this choice.
                    </p>
                    <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
                      {selectedCase.suspects.map((s, i) => (
                        <button key={i} onClick={() => accuse(s.name)} style={{
                          background: "#faf6ed", border: "1px solid #8b1a1a", color: "#2a1410",
                          padding: "12px 16px", cursor: "pointer", fontSize: 11, letterSpacing: 1,
                          textAlign: "left", fontFamily: "'Georgia', serif",
                          transition: "all 0.15s",
                        }}
                          onMouseEnter={e => { e.currentTarget.style.background = "#8b1a1a"; e.currentTarget.style.color = "#f0ebe0"; }}
                          onMouseLeave={e => { e.currentTarget.style.background = "#faf6ed"; e.currentTarget.style.color = "#2a1410"; }}
                        >
                          ▸ {s.name}
                        </button>
                      ))}
                    </div>
                  </div>
                ) : (
                  <div style={{ ...S.box("#f8f6f0"), textAlign: "center" }}>
                    <p style={{ fontSize: 11, color: "#9a8a7a", letterSpacing: 3 }}>
                      EXAMINE AT LEAST {2 - unlockedEvidence.length} MORE EVIDENCE FILE{2 - unlockedEvidence.length !== 1 ? "S" : ""} TO PROCEED TO ACCUSATION
                    </p>
                  </div>
                )}
              </div>
            )}

            {/* VERDICT */}
            {phase === 4 && (
              <div>
                <div style={S.verdictBox(verdict === "CORRECT")}>
                  <div style={{ fontSize: 52, marginBottom: 12 }}>{verdict === "CORRECT" ? "⚖" : "✗"}</div>
                  <div style={{ fontSize: 9, letterSpacing: 8, color: verdict === "CORRECT" ? "#2a6a2a" : "#8b1a1a", marginBottom: 10 }}>
                    {verdict === "CORRECT" ? "ACCUSATION SUSTAINED" : "ACCUSATION REJECTED"}
                  </div>
                  <h2 style={{ fontSize: 26, fontWeight: "bold", letterSpacing: 1, margin: "0 0 6px", color: verdict === "CORRECT" ? "#1a4a1a" : "#6a1010" }}>
                    {verdict === "CORRECT" ? `${accusation}` : `${accusation} WAS INNOCENT`}
                  </h2>
                  {verdict === "CORRECT" && <p style={{ color: "#2a6a2a", fontSize: 13 }}>Your accusation was correct. The case is closed — for the murder. The environmental crime continues.</p>}
                  {verdict === "WRONG" && (
                    <p style={{ color: "#6a2a2a", fontSize: 13 }}>
                      The actual perpetrator: <strong>{selectedCase.suspects.find(s => s.guilty)?.name}</strong>
                    </p>
                  )}
                </div>

                <div style={{ ...S.box("#fdf8f0"), marginBottom: 16 }}>
                  <p style={S.label()}>📁 FULL CASE RESOLUTION</p>
                  <p style={{ ...S.bodyText, fontSize: 13 }}>{selectedCase.solution}</p>
                </div>

                <div style={{ ...S.box("#faf6ed"), marginBottom: 16 }}>
                  <p style={S.label("#2a1e14")}>🗃 WHAT EVERY SUSPECT WAS CONCEALING</p>
                  {selectedCase.suspects.map((s, i) => (
                    <div key={i} style={{ display: "flex", gap: 16, padding: "10px 0", borderBottom: i < selectedCase.suspects.length - 1 ? "1px solid #d8c8a8" : "none" }}>
                      <div style={{ width: 180, flexShrink: 0, fontSize: 10, fontWeight: "bold", letterSpacing: 1, color: "#5a3828", paddingTop: 2 }}>
                        {s.name} {s.guilty && <span style={{ color: "#8b1a1a" }}>★ GUILTY</span>}
                      </div>
                      <div style={{ fontSize: 12, color: "#4a3828", lineHeight: 1.65 }}>{s.secret}</div>
                    </div>
                  ))}
                </div>

                <div style={{ ...S.box("#f0f4ff"), border: "1px solid #8090c0", marginBottom: 24 }}>
                  <p style={{ ...S.label("#2a4a8b") }}>📚 HISTORICAL RECORD</p>
                  <p style={{ ...S.bodyText, fontSize: 12 }}>{selectedCase.realInspiration}</p>
                </div>

                <div style={{ display: "flex", gap: 12 }}>
                  <button style={S.btn("primary")} onClick={() => setScreen("home")}>← RETURN TO ARCHIVE</button>
                  <button style={S.btn("ghost")} onClick={() => {
                    setPhase(1); setOpenSuspect(null); setUnlockedEvidence([]); setUnlockedSecrets([]);
                    setAccusation(null); setVerdict(null);
                  }}>↺ RETRY CASE</button>
                </div>
              </div>
            )}
          </div>
        )}
      </div>

      {/* footer */}
      <div style={{
        borderTop: "1px solid #d8c8a8", padding: "14px 32px", textAlign: "center",
        fontSize: 9, color: "#a89a8a", letterSpacing: 4, background: "#f0ebe0",
        position: "relative", zIndex: 1,
      }}>
        ALL CASES INSPIRED BY DOCUMENTED EUROPEAN ENVIRONMENTAL CRIMES — CHARACTERS FICTIONALISED — © DOSSIER EUROPA
      </div>
    </div>
  );
}
